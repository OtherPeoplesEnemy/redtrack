# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://redtrack:redtrack_secret@db:5432/redtrack

# ─── Security ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=changeme_generate_with_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── AI Provider ─────────────────────────────────────────────────────────────
# Set AI_PROVIDER to either "anthropic" or "gemini"
AI_PROVIDER=gemini

# Anthropic (https://console.anthropic.com)
ANTHROPIC_API_KEY=

# Google Gemini (https://aistudio.google.com)
GEMINI_API_KEY=

# ─── App ─────────────────────────────────────────────────────────────────────
APP_NAME=RedTrack
APP_ENV=development
CORS_ORIGINS=https://localhost,https://127.0.0.1

# ─── File Uploads ────────────────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=25

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── CLI API Keys ─────────────────────────────────────────────────────────────
# These are generated per-user in the app settings
# Leave blank here - managed through the UI

#!/usr/bin/env python3
"""
redtrack-cli — RedTrack Connector for Kali Linux & Windows
Send findings, push Nmap results, and update engagements from the command line.

Usage:
  redtrack-cli config                          # Set server URL and API key
  redtrack-cli engagements                     # List active engagements
  redtrack-cli finding add <engagement_id>     # Add a finding interactively
  redtrack-cli finding quick                   # Quick add a finding (minimal fields)
  redtrack-cli nmap <file.xml> <engagement_id> # Import Nmap XML results
  redtrack-cli hosts list <engagement_id>      # List recon hosts
  redtrack-cli status                          # Check connection to RedTrack server

Install:
  pip install requests python-libnmap colorama
  chmod +x redtrack-cli
  ./redtrack-cli config
"""

import os
import sys
import json
import argparse
import configparser
from pathlib import Path

try:
    import requests
    from colorama import init, Fore, Style
    init(autoreset=True)
except ImportError:
    print("Missing dependencies. Run: pip install requests colorama")
    sys.exit(1)

# ─── Config ───────────────────────────────────────────────────────────────────

CONFIG_FILE = Path.home() / ".redtrack" / "config.ini"

def load_config() -> dict:
    config = configparser.ConfigParser()
    if CONFIG_FILE.exists():
        config.read(CONFIG_FILE)
        return {
            "url": config.get("server", "url", fallback=""),
            "api_key": config.get("server", "api_key", fallback=""),
        }
    return {"url": "", "api_key": ""}

def save_config(url: str, api_key: str):
    CONFIG_FILE.parent.mkdir(parents=True, exist_ok=True)
    config = configparser.ConfigParser()
    config["server"] = {"url": url.rstrip("/"), "api_key": api_key}
    with open(CONFIG_FILE, "w") as f:
        config.write(f)
    os.chmod(CONFIG_FILE, 0o600)
    print(f"{Fore.GREEN}[✓] Config saved to {CONFIG_FILE}")

# ─── API Client ───────────────────────────────────────────────────────────────

class RedTrackClient:
    def __init__(self):
        cfg = load_config()
        self.base_url = cfg["url"]
        self.api_key = cfg["api_key"]
        if not self.base_url or not self.api_key:
            print(f"{Fore.RED}[!] Not configured. Run: redtrack-cli config")
            sys.exit(1)
        self.session = requests.Session()
        self.session.headers.update({
            "X-API-Key": self.api_key,
            "Content-Type": "application/json",
        })
        self.session.verify = False  # Self-signed cert
        import urllib3
        urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

    def get(self, path: str) -> dict:
        r = self.session.get(f"{self.base_url}/api{path}")
        r.raise_for_status()
        return r.json()

    def post(self, path: str, data: dict) -> dict:
        r = self.session.post(f"{self.base_url}/api{path}", json=data)
        r.raise_for_status()
        return r.json()

    def patch(self, path: str, data: dict) -> dict:
        r = self.session.patch(f"{self.base_url}/api{path}", json=data)
        r.raise_for_status()
        return r.json()

# ─── Commands ─────────────────────────────────────────────────────────────────

def cmd_config(args):
    print(f"\n{Fore.CYAN}RedTrack CLI Configuration{Style.RESET_ALL}")
    print("─" * 40)
    current = load_config()
    url = input(f"Server URL [{current['url'] or 'https://192.168.0.48'}]: ").strip()
    api_key = input(f"API Key [{current['api_key'][:8] + '...' if current['api_key'] else 'not set'}]: ").strip()
    if not url:
        url = current["url"] or "https://192.168.0.48"
    if not api_key:
        api_key = current["api_key"]
    save_config(url, api_key)


def cmd_status(args):
    client = RedTrackClient()
    try:
        r = client.get("/health")
        print(f"{Fore.GREEN}[✓] Connected to {client.base_url}")
        print(f"    Service: {r.get('service')} v{r.get('version')}")
    except Exception as e:
        print(f"{Fore.RED}[!] Connection failed: {e}")


def cmd_engagements(args):
    client = RedTrackClient()
    engs = client.get("/engagements/")
    if not engs:
        print(f"{Fore.YELLOW}[!] No engagements found")
        return
    print(f"\n{Fore.CYAN}{'ID':<12} {'Ref':<10} {'Client':<20} {'Name':<30} {'Type':<15} {'Status'}")
    print("─" * 100)
    for e in engs:
        status_color = Fore.GREEN if e["status"] == "Active" else Fore.YELLOW if e["status"] == "Planning" else Fore.WHITE
        print(f"{str(e['id'])[:8]:<12} {e['ref_id']:<10} {e['client'][:18]:<20} {e['name'][:28]:<30} {e['type']:<15} {status_color}{e['status']}")


def cmd_finding_add(args):
    client = RedTrackClient()
    eng_id = args.engagement_id

    print(f"\n{Fore.CYAN}Add Finding to Engagement{Style.RESET_ALL}")
    print("─" * 40)

    title = input("Title: ").strip()
    if not title:
        print(f"{Fore.RED}[!] Title is required")
        return

    print("Severity [1=Critical, 2=High, 3=Medium, 4=Low, 5=Info]: ", end="")
    sev_map = {"1": "Critical", "2": "High", "3": "Medium", "4": "Low", "5": "Info"}
    sev = sev_map.get(input().strip(), "High")

    cvss = input("CVSS Score (0.0-10.0, or Enter to skip): ").strip()
    cwe = input("CWE (e.g. CWE-89, or Enter to skip): ").strip()
    affected = input("Affected Component: ").strip()
    description = input("Description: ").strip()
    steps = input("Steps to Reproduce (brief): ").strip()
    remediation = input("Remediation: ").strip()

    payload = {
        "title": title,
        "severity": sev,
        "cvss_score": float(cvss) if cvss else None,
        "cwe": cwe or None,
        "affected_component": affected or None,
        "description": description or None,
        "steps_to_reproduce": steps or None,
        "remediation": remediation or None,
        "source": "cli",
    }

    try:
        result = client.post(f"/findings/{eng_id}", payload)
        print(f"\n{Fore.GREEN}[✓] Finding added: {result['ref_id']} — {result['title']}")
    except Exception as e:
        print(f"{Fore.RED}[!] Failed to add finding: {e}")


def cmd_finding_quick(args):
    """Quick one-liner finding submission."""
    client = RedTrackClient()

    engs = client.get("/engagements/")
    active = [e for e in engs if e["status"] == "Active"]
    if not active:
        print(f"{Fore.RED}[!] No active engagements")
        return

    print(f"\n{Fore.CYAN}Active Engagements:{Style.RESET_ALL}")
    for i, e in enumerate(active):
        print(f"  {i+1}. {e['ref_id']} — {e['client']} ({e['name']})")

    idx = input("\nSelect engagement number: ").strip()
    try:
        eng = active[int(idx) - 1]
    except (ValueError, IndexError):
        print(f"{Fore.RED}[!] Invalid selection")
        return

    title = input("Finding title: ").strip()
    sev_map = {"c": "Critical", "h": "High", "m": "Medium", "l": "Low", "i": "Info"}
    sev_input = input("Severity [c/h/m/l/i]: ").strip().lower()
    sev = sev_map.get(sev_input, "High")

    payload = {"title": title, "severity": sev, "source": "cli"}

    try:
        result = client.post(f"/findings/{eng['id']}", payload)
        print(f"{Fore.GREEN}[✓] {result['ref_id']} added to {eng['ref_id']}")
    except Exception as e:
        print(f"{Fore.RED}[!] Error: {e}")


def cmd_nmap(args):
    """Import Nmap XML results into the Recon tab of an engagement."""
    try:
        from libnmap.parser import NmapParser
    except ImportError:
        print(f"{Fore.RED}[!] python-libnmap required: pip install python-libnmap")
        sys.exit(1)

    client = RedTrackClient()
    xml_file = args.xml_file
    eng_id = args.engagement_id

    if not Path(xml_file).exists():
        print(f"{Fore.RED}[!] File not found: {xml_file}")
        return

    print(f"{Fore.CYAN}[*] Parsing Nmap results from {xml_file}...")

    report = NmapParser.parse_fromfile(xml_file)
    hosts_added = 0

    for host in report.hosts:
        if host.status != "up":
            continue

        ports = []
        services = []
        for svc in host.services:
            ports.append(svc.port)
            services.append({
                "port": svc.port,
                "protocol": svc.protocol,
                "state": svc.state,
                "service": svc.service,
                "banner": svc.banner,
            })

        payload = {
            "ip_address": host.address,
            "hostname": host.hostnames[0] if host.hostnames else None,
            "os": host.os_match_probabilities()[0].name if host.os_match_probabilities() else None,
            "ports": ports,
            "services": services,
            "status": "up",
            "source": "nmap",
        }

        try:
            client.post(f"/recon/{eng_id}/hosts", payload)
            hosts_added += 1
            print(f"  {Fore.GREEN}[+] {host.address} — {len(ports)} ports")
        except Exception as e:
            print(f"  {Fore.RED}[!] Failed to add {host.address}: {e}")

    print(f"\n{Fore.GREEN}[✓] Imported {hosts_added} hosts to engagement")
    print(f"    View in RedTrack: Engagements → Recon tab")


def cmd_hosts_list(args):
    client = RedTrackClient()
    try:
        hosts = client.get(f"/recon/{args.engagement_id}/hosts")
        if not hosts:
            print(f"{Fore.YELLOW}[!] No hosts found for this engagement")
            return
        print(f"\n{Fore.CYAN}{'IP Address':<18} {'Hostname':<30} {'OS':<25} {'Ports'}")
        print("─" * 90)
        for h in hosts:
            ports = ", ".join(str(p) for p in (h.get("ports") or [])[:10])
            print(f"{h['ip_address']:<18} {(h.get('hostname') or '—')[:28]:<30} {(h.get('os') or '—')[:23]:<25} {ports}")
    except Exception as e:
        print(f"{Fore.RED}[!] Error: {e}")


# ─── Main ─────────────────────────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(
        prog="redtrack-cli",
        description="RedTrack CLI — Send findings and recon data to RedTrack",
    )
    subparsers = parser.add_subparsers(dest="command")

    # config
    subparsers.add_parser("config", help="Configure server URL and API key")

    # status
    subparsers.add_parser("status", help="Check connection to RedTrack server")

    # engagements
    subparsers.add_parser("engagements", help="List active engagements")

    # finding
    finding_parser = subparsers.add_parser("finding", help="Manage findings")
    finding_sub = finding_parser.add_subparsers(dest="finding_cmd")

    add_parser = finding_sub.add_parser("add", help="Add a finding interactively")
    add_parser.add_argument("engagement_id", help="Engagement UUID")

    finding_sub.add_parser("quick", help="Quick add a finding")

    # nmap
    nmap_parser = subparsers.add_parser("nmap", help="Import Nmap XML results")
    nmap_parser.add_argument("xml_file", help="Path to Nmap XML output file")
    nmap_parser.add_argument("engagement_id", help="Engagement UUID")

    # hosts
    hosts_parser = subparsers.add_parser("hosts", help="Manage recon hosts")
    hosts_sub = hosts_parser.add_subparsers(dest="hosts_cmd")
    list_parser = hosts_sub.add_parser("list", help="List recon hosts")
    list_parser.add_argument("engagement_id", help="Engagement UUID")

    args = parser.parse_args()

    print(f"{Fore.RED}{'─'*50}")
    print(f"{Fore.RED}  RedTrack CLI  {Fore.WHITE}Pentest Management Connector")
    print(f"{Fore.RED}{'─'*50}{Style.RESET_ALL}")

    if args.command == "config":
        cmd_config(args)
    elif args.command == "status":
        cmd_status(args)
    elif args.command == "engagements":
        cmd_engagements(args)
    elif args.command == "finding":
        if args.finding_cmd == "add":
            cmd_finding_add(args)
        elif args.finding_cmd == "quick":
            cmd_finding_quick(args)
        else:
            finding_parser.print_help()
    elif args.command == "nmap":
        cmd_nmap(args)
    elif args.command == "hosts":
        if args.hosts_cmd == "list":
            cmd_hosts_list(args)
        else:
            hosts_parser.print_help()
    else:
        parser.print_help()


if __name__ == "__main__":
    main()
